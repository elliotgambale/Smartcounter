{
  "expo": {
    "name": "SmartCounter",
    "slug": "smart-counter",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "smartcounter",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.smartcounter.demo",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "SmartCounter needs Bluetooth to connect to your ESP32 device.",
        "NSBluetoothPeripheralUsageDescription": "SmartCounter needs Bluetooth to connect to your ESP32 device.",
        "UIBackgroundModes": [
          "bluetooth-central",
          "bluetooth-central"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": [
            "peripheral",
            "central"
          ],
          "bluetoothAlwaysPermission": "Allow SmartCounter to use Bluetooth to connect to your gym device."
        }
      ],
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4a085d79-9891-466d-9554-6c5c7fbf17d4"
      }
    }
  }
}
